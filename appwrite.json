{
    "projectName": "cver menus",
    "databases": [
        {
            "$id": "cver",
            "name": "cver",
            "enabled": true
        }
    ],
    "collections": [
        {
            "$id": "menu",
            "$permissions": [
                "read(\"any\")",
                "read(\"guests\")",
                "read(\"users\")"
            ],
            "databaseId": "cver",
            "name": "menu",
            "enabled": true,
            "documentSecurity": false,
            "attributes": [
                {
                    "key": "dow",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 20,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "date",
                    "type": "datetime",
                    "required": true,
                    "array": false,
                    "format": "",
                    "default": null
                },
                {
                    "key": "description",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 8000,
                    "default": null,
                    "encrypt": false
                }
            ],
            "indexes": [
                {
                    "key": "search",
                    "type": "fulltext",
                    "status": "available",
                    "attributes": [
                        "description"
                    ],
                    "orders": [
                        "ASC"
                    ]
                },
                {
                    "key": "date_unique",
                    "type": "unique",
                    "status": "available",
                    "attributes": [
                        "date"
                    ],
                    "orders": [
                        "ASC"
                    ]
                }
            ]
        },
        {
            "$id": "system_queue",
            "$permissions": [],
            "databaseId": "cver",
            "name": "system_queue",
            "enabled": true,
            "documentSecurity": false,
            "attributes": [
                {
                    "key": "function_id",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 100,
                    "encrypt": false
                },
                {
                    "key": "payload",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 1000000,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "status",
                    "type": "string",
                    "required": true,
                    "array": false,
                    "size": 20,
                    "encrypt": false
                },
                {
                    "key": "retries",
                    "type": "integer",
                    "required": false,
                    "array": false,
                    "default": 0
                },
                {
                    "key": "error_log",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 1000000,
                    "default": null,
                    "encrypt": false
                }
            ],
            "indexes": [
                {
                    "key": "status_idx",
                    "type": "key",
                    "status": "available",
                    "attributes": [
                        "status"
                    ],
                    "orders": [
                        "ASC"
                    ]
                }
            ]
        },
        {
            "$id": "system_locks",
            "$permissions": [],
            "databaseId": "cver",
            "name": "system_locks",
            "enabled": true,
            "documentSecurity": false,
            "attributes": [
                {
                    "key": "locked_at",
                    "type": "datetime",
                    "required": true,
                    "array": false,
                    "format": ""
                }
            ],
            "indexes": []
        }
    ],
    "functions": [
        {
            "$id": "menu_parser",
            "name": "Menu Parser",
            "runtime": "python-3.11",
            "path": "functions/menu_parser",
            "entrypoint": "src/cver.py",
            "commands": "pip install -r requirements.txt",
            "ignore": [
                "__pypackages__"
            ],
            "execute": [],
            "events": [],
            "schedule": "0 17,23 * * 0,5",
            "timeout": 60,
            "enabled": true,
            "logging": true,
            "scopes": [
                "documents.read",
                "documents.write"
            ],
            "specification": "s-1vcpu-512mb"
        },
        {
            "$id": "menu_image",
            "execute": [
                "any"
            ],
            "name": "Menu Image Generator",
            "enabled": true,
            "logging": true,
            "runtime": "python-3.11",
            "scopes": [
                "documents.read",
                "documents.write",
                "files.read",
                "files.write"
            ],
            "events": [],
            "schedule": "",
            "timeout": 300,
            "entrypoint": "generate.py",
            "commands": "pip install -r requirements.txt",
            "specification": "s-1vcpu-512mb",
            "path": "functions/menu_image"
        },
        {
            "$id": "queue_trigger",
            "execute": [],
            "name": "Queue Trigger",
            "enabled": true,
            "logging": true,
            "runtime": "python-3.11",
            "scopes": [
                "documents.write",
                "execution.write"
            ],
            "events": [
                "databases.cver.collections.menu.documents.*.create"
            ],
            "schedule": "",
            "timeout": 15,
            "entrypoint": "main.py",
            "commands": "pip install -r requirements.txt",
            "specification": "s-1vcpu-512mb",
            "path": "functions/queue_trigger"
        },
        {
            "$id": "queue_worker",
            "execute": [],
            "name": "Queue Worker",
            "enabled": true,
            "logging": true,
            "runtime": "python-3.11",
            "scopes": [
                "documents.read",
                "documents.write",
                "execution.read",
                "execution.write"
            ],
            "events": [],
            "schedule": "",
            "timeout": 900,
            "entrypoint": "main.py",
            "commands": "pip install -r requirements.txt",
            "specification": "s-1vcpu-512mb",
            "path": "functions/queue_worker"
        }
    ],
    "projectId": "689e2e4a0004e00d8fa4",
    "buckets": [
        {
            "$id": "cver",
            "$permissions": [
                "read(\"any\")"
            ],
            "fileSecurity": false,
            "name": "cver",
            "enabled": true,
            "maximumFileSize": 30000000,
            "allowedFileExtensions": [
                "jpg"
            ],
            "compression": "none",
            "encryption": false,
            "antivirus": false
        }
    ]
}